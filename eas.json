{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        // Left empty on purpose: `eas submit -p ios --profile production` prompts
        // for your Apple ID interactively and matches the app by bundle id
        // (com.chatethehook.app), so no credentials are stored in git.
        //
        // To skip the prompts later, fill these in:
        //   "appleId": "you@example.com",            // App Store Connect login email
        //   "ascAppId": "1234567890",                // App Store Connect > App Information > "Apple ID"
        //   "appleTeamId": "XXXXXXXXXX"              // developer.apple.com > Membership
        //
        // Or use an App Store Connect API key (best for CI — no password prompt):
        //   "ascApiKeyPath": "./credentials/asc-api-key.p8",
        //   "ascApiKeyId": "YOUR_KEY_ID",
        //   "ascApiKeyIssuerId": "YOUR_ISSUER_ID"
      },
      "android": {
        // Path to the Google Play service account JSON key. Keep this file OUT of git.
        "serviceAccountKeyPath": "./credentials/google-play-service-account.json",
        // First release track. Use "internal" while testing, then switch to "production" to go live.
        "track": "internal",
        // "completed" = release immediately; "draft" lets you finish the rollout manually in Play Console.
        "releaseStatus": "completed"
      }
    }
  }
}
