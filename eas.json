{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        // Apple ID email used to sign in to App Store Connect.
        // Tip: omit this and set the EXPO_APPLE_ID env var instead to keep it out of git.
        "appleId": "YOUR_APPLE_ID_EMAIL",
        // Numeric App Store Connect app ID (App Store Connect > your app > App Information > "Apple ID").
        "ascAppId": "YOUR_ASC_APP_ID",
        // Apple Developer Team ID (developer.apple.com/account > Membership details).
        "appleTeamId": "YOUR_APPLE_TEAM_ID"

        // --- CI / non-interactive alternative (recommended for automation) ---
        // Replace appleId above with an App Store Connect API key so EAS never prompts for a password:
        // "ascApiKeyPath": "./credentials/asc-api-key.p8",
        // "ascApiKeyId": "YOUR_KEY_ID",
        // "ascApiKeyIssuerId": "YOUR_ISSUER_ID"
      },
      "android": {
        // Path to the Google Play service account JSON key. Keep this file OUT of git.
        "serviceAccountKeyPath": "./credentials/google-play-service-account.json",
        // First release track. Use "internal" while testing, then switch to "production" to go live.
        "track": "internal",
        // "completed" = release immediately; "draft" lets you finish the rollout manually in Play Console.
        "releaseStatus": "completed"
      }
    }
  }
}
